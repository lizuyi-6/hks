# Application Ports
WEB_PORT=3000
API_PORT=8000
WORKER_POLL_INTERVAL=5
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_PROXY_BASE=/api/backend
NEXT_PUBLIC_DEFAULT_DATA_MODE=real
NEXT_PUBLIC_API_MODE=mock
NEXT_PRIVATE_API_BASE_URL=http://localhost:8000

# Application Environment
APP_ENV=development
APP_SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database Configuration
# SQLite (default - for local development without Docker)
# DATABASE_URL=sqlite:///apps/api/test.db

# MySQL (via Docker Compose)
# DATABASE_URL=mysql+pymysql://a1plus_user:a1plus_password@localhost:3306/a1plus

# PostgreSQL (via Docker Compose)
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/a1plus

# Redis
REDIS_URL=redis://redis:6379/0

# Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@a1plus.local
SMTP_USE_TLS=true

# LLM Configuration
# Supported providers: dashscope, deepseek, doubao, or custom (set LLM_BASE_URL)
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# External APIs
TIANAYANCHA_API_KEY=
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Feature Flags
FEATURE_ANALYTICS=true
FEATURE_ANALYTICS_DEBUG=true
FEATURE_MONITORING_PUBLIC_SEARCH=true
FEATURE_MONITORING_AUTHORIZED_API=false
FEATURE_MONITORING_AUTHORIZED_SCRAPE=false
FEATURE_COMPETITORS=true
FEATURE_CONTRACT_REVIEW=true
FEATURE_PATENT_ASSIST=true
FEATURE_POLICY_DIGEST=true
FEATURE_DUE_DILIGENCE=true

# Provider Modes (real/mock)
PROVIDER_TRADEMARK_SEARCH_MODE=real
PROVIDER_ENTERPRISE_LOOKUP_MODE=real
PROVIDER_PUBLIC_WEB_SEARCH_MODE=real
PROVIDER_KNOWLEDGE_BASE_MODE=real
PROVIDER_LLM_MODE=real
PROVIDER_DOCUMENT_RENDER_MODE=real
PROVIDER_NOTIFICATION_MODE=real
PROVIDER_MONITORING_MODE=real
PROVIDER_SUBMISSION_GUIDE_MODE=real
