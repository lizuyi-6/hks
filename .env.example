# Application Ports
WEB_PORT=3000
API_PORT=8000
WORKER_POLL_INTERVAL=5
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_PROXY_BASE=/api/backend
NEXT_PUBLIC_DEFAULT_DATA_MODE=real
NEXT_PRIVATE_API_BASE_URL=http://localhost:8000

# Application Environment
APP_ENV=development
APP_SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Master key for encrypting at-rest provider credentials (provider_integrations table).
# REQUIRED when APP_ENV != development/test. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: rotating this key without re-encrypting existing rows will make every stored
# secret undecryptable. Keep it in a secret manager, never commit it.
APP_ENCRYPTION_KEY=

# Database Configuration
# SQLite (default - for local development without Docker)
# DATABASE_URL=sqlite:///apps/api/test.db

# MySQL (via Docker Compose)
# DATABASE_URL=mysql+pymysql://a1plus_user:a1plus_password@localhost:3306/a1plus

# PostgreSQL (via Docker Compose)
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/a1plus

# Redis
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# External provider credentials — **fallback only**
# ---------------------------------------------------------------------------
# Preferred path: each tenant configures their own key via the frontend
# "企业合规中心 → 集成配置" tab, which writes a Fernet-encrypted row into
# the `provider_integrations` table.
#
# The env vars below are consulted ONLY as last-resort fallbacks when no
# tenant-scoped row AND no global (tenant_id = NULL) row exist for a given
# provider. Leave them blank in production if every tenant brings their own
# key.
#
# See apps/api/app/db/repositories/integrations.py for the resolution order:
#   tenant-scoped row → global row → env var fallback.
# ---------------------------------------------------------------------------

# Email Configuration (SMTP fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@a1plus.local
SMTP_USE_TLS=true

# LLM (Doubao / Volcengine Ark) — fallback only.
# These vars are used when the `doubao_llm` provider has no DB row.
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DOUBAO_MODEL=Doubao-Seed-2.0-pro

# Enterprise lookup / competitor tracking (Tianyancha fallback)
TIANAYANCHA_API_KEY=

# Public web search (Bing fallback)
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Feature Flags
FEATURE_ANALYTICS=true
FEATURE_ANALYTICS_DEBUG=true
FEATURE_MONITORING_PUBLIC_SEARCH=true
FEATURE_MONITORING_AUTHORIZED_API=false
FEATURE_MONITORING_AUTHORIZED_SCRAPE=false
FEATURE_COMPETITORS=true
FEATURE_CONTRACT_REVIEW=true
FEATURE_PATENT_ASSIST=true
FEATURE_POLICY_DIGEST=true
FEATURE_DUE_DILIGENCE=true

# ---------------------------------------------------------------------------
# 需求画像 / 智能匹配（7 支柱赛道）
#   - PROFILE_MATCHING_MODE=rules|embedding
#       rules     规则 rerank（默认）
#       embedding 基于标签向量的 cosine 相似度 rerank，更稳的"为什么匹配"叙事
# ---------------------------------------------------------------------------
PROFILE_MATCHING_MODE=rules
