{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@a1plus/domain": ["packages/domain/src/index.ts"],
      "@a1plus/config": ["packages/config/src/index.ts"],
      "@a1plus/ui": ["packages/ui/src/index.tsx"]
    }
  }
}

