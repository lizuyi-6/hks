{
  "name": "a1plus-ip-coworker",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @a1plus/web",
    "build:web": "npm run build --workspace @a1plus/web",
    "lint:web": "npm run lint --workspace @a1plus/web",
    "test:web": "npm run test --workspace @a1plus/web",
    "test:api": "python -m pytest apps/api/tests apps/worker/tests",
    "test": "npm run test:web && npm run test:api"
  },
  "devDependencies": {
    "pptxgenjs": "^4.0.1"
  }
}
