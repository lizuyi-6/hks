{
  "name": "a1plus-ip-coworker",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @a1plus/web",
    "build:web": "npm run build --workspace @a1plus/web",
    "lint:web": "npm run lint --workspace @a1plus/web",
    "test:web": "npm run test --workspace @a1plus/web",
    "test:api": "python -m pytest apps/api/tests apps/worker/tests apps/cli/tests",
    "test": "npm run test:web && npm run test:api"
  },
  "devDependencies": {
    "pptxgenjs": "^4.0.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
